    // ===== 组件集合预设（用于"常用组件集合"菜单） =====
    // 每个组：组名（option::none 表示直接 MenuItem 而非子菜单）+ 一组叶子节点
    public using ComponentPresetLeaf = struct {
        public label: string,
        public components: array<string>,
    };

    public using ComponentPresetGroup = struct {
        public submenu_label: option<string>,   // none = 顶层叶子项（仅第一个叶子有效）；value = 子菜单标题
        public leaves: array<ComponentPresetLeaf>,
        public separator_before: bool,          // 此组前是否绘制分隔线
    };

    public let COMPONENT_PRESET_GROUPS = [
        ComponentPresetGroup {
            submenu_label = option::none,
            separator_before = false,
            leaves = [
                ComponentPresetLeaf { label = "移除全部组件", components = [] },
            ],
        },
        ComponentPresetGroup {
            submenu_label = option::value("变换（Transform）"),
            separator_before = true,
            leaves = [
                ComponentPresetLeaf { label = "一般变换", components = BASE_TRANSFORM_COMPONENTS },
                ComponentPresetLeaf { label = "UI变换", components = UI_TRANSFORM_COMPONENTS },
            ],
        },
        ComponentPresetGroup {
            submenu_label = option::none,
            separator_before = false,
            leaves = [
