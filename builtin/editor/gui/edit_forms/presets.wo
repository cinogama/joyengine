                ComponentPresetLeaf { label = "平行光源", components = LIGHT2D_PARALLEL_COMPONENTS },
            ],
        },
        ComponentPresetGroup {
            submenu_label = option::value("2D阴影（Shadow2D）"),
            separator_before = false,
            leaves = [
                ComponentPresetLeaf { label = "常用组合", components = LIGHT2D_SHADOW_COMMON_COMPONENTS },
                ComponentPresetLeaf { label = "形状", components = ["Light2D::ShapeShadow"] },
                ComponentPresetLeaf { label = "块投射", components = ["Light2D::BlockShadow"] },
                ComponentPresetLeaf { label = "精灵图（俯视角）", components = ["Light2D::SpriteShadow"] },
                ComponentPresetLeaf { label = "自身", components = ["Light2D::SelfShadow"] },
            ],
        },
        ComponentPresetGroup {
            submenu_label = option::value("摄像机（Camera）"),
            separator_before = false,
            leaves = [
