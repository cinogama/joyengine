    // ===== 实体快速创建预设（用于"快速创建实体"菜单） =====
    public using EntityPreset = struct {
        public menu_label: string,                  // 菜单显示文本
        public entity_name: string,                 // 创建时的实体名
        public components: array<string>,           // 组件类型名列表
        public default_shader: option<string>,      // 创建后自动加载的着色器（可选）
    };

    // 用于分隔不同语义类别的预设组
    public using EntityPresetGroup = struct {
        public separator_before: bool,              // 此组前是否绘制分隔线
        public presets: array<EntityPreset>,
    };

    public let ENTITY_PRESET_GROUPS = [
        EntityPresetGroup {
            separator_before = false,
            presets = [
                EntityPreset {
                    menu_label   = "基本渲染实体",
                    entity_name  = "默认物体",
                    components   = BASE_TRANSFORM_COMPONENTS->connect(BASE_RENDERER_COMPONENTS),
                    default_shader = option::none,
                },
                EntityPreset {
                    menu_label   = "基本UI",
                    entity_name  = "默认UI",
                    components   = [
