                ComponentPresetLeaf { label = "仅UI投影", components = CAMERA_UI_ONLY_COMPONENTS },
                ComponentPresetLeaf { label = "2D光照后处理流程", components = CAMERA_2D_LIGHT_POSTPASS_COMPONENTS },
            ],
        },
        ComponentPresetGroup {
            submenu_label = option::value("2D物理（Physics2D）"),
            separator_before = false,
            leaves = [
                ComponentPresetLeaf { label = "静态", components = PHYSICS2D_STATIC_COMPONENTS },
                ComponentPresetLeaf { label = "动力学", components = PHYSICS2D_DYNAMIC_COMPONENTS },
                ComponentPresetLeaf { label = "高速动力学", components = PHYSICS2D_FAST_DYNAMIC_COMPONENTS },
                ComponentPresetLeaf { label = "触发器", components = PHYSICS2D_TRIGGER_COMPONENTS },
                ComponentPresetLeaf { label = "场景配置", components = PHYSICS2D_SCENE_COMPONENTS },
            ],
        },
    ];

    // ===== 菜单绘制辅助：根据 ComponentPresetGroup 渲染 MenuItem / BeginMenu =====
    // on_pick_components: 当用户选中某个叶子时，把对应组件列表传给它
    public func draw_component_preset_group(
        group: ComponentPresetGroup,
        on_pick_components: (array<string>)=>void,
        on_remove_all: ()=>void)
    {
        if (group.separator_before)
            Separator();

        match (group.submenu_label)
        {
            value(label)?
            {
                if (BeginMenu(label))
                {
                    for (let leaf : group.leaves)
                    {
                        if (MenuItem(leaf.label))
                            on_pick_components(leaf.components);
                    }
                    EndMenu();
                }
            }
            none?
            {
                // 顶层叶子；约定：leaves[0] 是叶子项。
                // 特殊约定：若 components 为空，调用 on_remove_all（用于"移除全部组件"）
                for (let leaf : group.leaves)
                {
                    if (MenuItem(leaf.label))
                    {
                        if (leaf.components->empty)
                            on_remove_all();
                        else
                            on_pick_components(leaf.components);
                    }
                }
            }
        }
    }

    // ===== 列表移动辅助：在多个 typeinfo 列表之间移动一个类型 =====
    // target  : 目标列表（如果 type 不在其中则加入）
    // others  : 需要从中移除 type 的其他列表
    // 找不到对应类型时调用 je::logfatal 输出 not_found_log + type_name
    public func move_type_between_lists(
        type_name: string,
        target: vec<je::typeinfo>,
        others: array<vec<je::typeinfo>>,
        not_found_log: string)
    {
        match (je::typeinfo::load(type_name))
        {
            value(type)?
            {
                if (target->find(type)->is_none)
                {
                    target->add(type);
                    for (let other : others)
                        do other->find(type)->> \idx = other->remove(idx);;
                }
            }
            none?
                je::logfatal(not_found_log, type_name);
        }
    }
}
