    public let ICON_PATH_FONT           = F"{ENGINE_BUILTIN_ROOT}/icon/Font.png";
    public let ICON_PATH_MUSIC          = F"{ENGINE_BUILTIN_ROOT}/icon/Music.png";
    public let ICON_PATH_PLUGIN         = F"{ENGINE_BUILTIN_ROOT}/icon/Plugins.png";
    public let ICON_PATH_SHADER_FILE    = F"{ENGINE_BUILTIN_ROOT}/icon/ShaderFile.png";
    public let ICON_PATH_CPP_PROGRAM    = F"{ENGINE_BUILTIN_ROOT}/icon/CppProgram.png";
    public let ICON_PATH_WORKFLOW       = F"{ENGINE_BUILTIN_ROOT}/icon/Workflow.png";
    public let ICON_PATH_WORLD          = F"{ENGINE_BUILTIN_ROOT}/icon/World.png";
    public let ICON_PATH_ENTITY         = F"{ENGINE_BUILTIN_ROOT}/icon/Entity.png";
    public let ICON_PATH_ANIMATION      = F"{ENGINE_BUILTIN_ROOT}/icon/AnimationFile.png";
    public let ICON_PATH_TILEMAP        = F"{ENGINE_BUILTIN_ROOT}/icon/Tilemap.png";
    public let ICON_PATH_PARTICAL       = F"{ENGINE_BUILTIN_ROOT}/icon/Partical.png";
    public let ICON_PATH_JOY            = F"{ENGINE_BUILTIN_ROOT}/icon/Joy.png";
    public let ICON_PATH_FILE_PATH      = F"{ENGINE_BUILTIN_ROOT}/icon/FilePath.png";
