// editor.common.constants
// 编辑器全局共享常量：文件扩展名、引擎路径、目录名等。
// 目的是消除散落在各文件中的字面量重复，集中管理命名约定。

namespace editor::common::constants
{
    // ===== JoyEngine 项目相关扩展名 =====
    public let EXT_PROJECT          = ".je4project";
    public let EXT_PROJECT_LOCK     = ".je4lock";
    public let EXT_WORLD           = ".je4world";
    public let EXT_ENTITY          = ".je4entity";
    public let EXT_ANIMATION       = ".je4animation";
    public let EXT_PARTICAL        = ".je4partical";
    public let EXT_TILEMAP         = ".je4tilemap";
    public let EXT_TILESET         = ".je4tileset";
    public let EXT_WORKFLOW_SET    = ".je4workflows";
    public let EXT_WORKFLOW        = ".je4workflow";
    public let EXT_MODULE          = ".je4module";
    public let EXT_CACHE           = ".je4cache";
    public let EXT_STYLE           = ".je4style";
    public let EXT_CHUNK           = ".je4chunk";
    public let EXT_CHUNKLIST       = ".je4chunklist";

    // ===== 编辑器/ToWoo Woolang 脚本扩展名 =====
    public let EXT_SHADER          = ".shader";
    public let EXT_WOOLANG         = ".wo";
    public let EXT_EDITOR_TOOL     = ".je.wo";
    public let EXT_TOWOO_COMPONENT = ".jecomponent.wo";
    public let EXT_TOWOO_SYSTEM    = ".jesystem.wo";
    public let EXT_PHYSICS2D_CFG   = ".jephysics2d.wo";

    // ===== 资源文件扩展名（图片/字体/音频） =====
    public let EXT_PNG             = ".png";
    public let EXT_JPG             = ".jpg";
    public let EXT_BMP             = ".bmp";
    public let EXT_PSD             = ".psd";
    public let EXT_TTF             = ".ttf";
    public let EXT_WAV             = ".wav";

    public let IMAGE_FILE_EXT_NAMES = [EXT_PNG, EXT_JPG, EXT_BMP, EXT_PSD];

    // ===== 引擎内置资源路径前缀 =====
    // "!" 前缀指向引擎安装目录，"@" 前缀指向当前运行时项目目录
    public let ENGINE_BUILTIN_ROOT = "!/builtin";
    public let PROJECT_RESOURCE_ROOT = "@/resource";
    public let SHADER_DIR          = "@/resource/shader";
    public let FONT_DIR            = "@/resource/font";
    public let TEXTURE_DIR         = "@/resource/texture";

    // ===== 编辑器内置图标（!/builtin/icon/*.png） =====
    public let ICON_PATH_CREATE         = F"{ENGINE_BUILTIN_ROOT}/icon/Create.png";
    public let ICON_PATH_LOAD           = F"{ENGINE_BUILTIN_ROOT}/icon/Load.png";
    public let ICON_PATH_EXIT           = F"{ENGINE_BUILTIN_ROOT}/icon/Exit.png";
    public let ICON_PATH_CINO_LOGO      = F"{ENGINE_BUILTIN_ROOT}/icon/cinoicon_light.png";
